# Environment Variables Template
# Copy this file to .env and fill in your actual values

# MongoDB Connection String
MONGODB_URI=

# Server Port (optional, defaults to 4000)
PORT=4000

# Frontend origin(s) for CORS — comma-separated for multiple domains
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com,https://www.yourdomain.com

# JWT Secret Key
JWT_SECRET=your-secret-key-here
ADMIN_JWT_SECRET=your-admin-secret-key-here

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Brevo Email Configuration
BREVO_API_KEY=
ADMIN_EMAIL=admin@yourdomain.com
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Vivek's Farm  
